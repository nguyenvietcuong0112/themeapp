<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item
                android:state_pressed="true"
                android:id="@+id/space_pressed"
                android:left="@dimen/tiny_margin"
                android:top="@dimen/small_margin"
                android:right="@dimen/tiny_margin"
                android:bottom="@dimen/small_margin">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/darker_gray"/>
                    <corners android:radius="@dimen/medium_margin"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item
                android:state_pressed="true"
                android:id="@+id/space_normal"
                android:left="@dimen/tiny_margin"
                android:top="@dimen/small_margin"
                android:right="@dimen/tiny_margin"
                android:bottom="@dimen/small_margin">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/darker_gray"/>
                    <corners android:radius="@dimen/medium_margin"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
