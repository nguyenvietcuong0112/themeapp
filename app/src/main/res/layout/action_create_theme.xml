<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_corner_24_top"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@color/grayF2F2F2"
    android:paddingVertical="@dimen/dp_8">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivReset"
            android:padding="@dimen/dp_2"
            android:layout_width="@dimen/dp_28"
            android:layout_height="@dimen/dp_28"
            android:foreground="?android:attr/selectableItemBackground"
            android:src="@drawable/ic_reset"
            android:tint="?attr/titleTextColor"
            android:layout_marginStart="@dimen/dp_16"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="?attr/titleTextColor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/customize"
            android:fontFamily="@font/helvetica_medium"
            android:textAlignment="center"
            android:layout_marginHorizontal="@dimen/dp_64"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/colorFF819F"
            android:gravity="center"
            android:id="@+id/tvSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackground"
            android:text="@string/save"
            android:fontFamily="@font/helvetica_medium"
            android:layout_marginEnd="@dimen/dp_16"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_marginBottom="@dimen/dp_8">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/llIcon"
            android:background="@drawable/bg_corner_8"
            android:layout_width="@dimen/dp_84"
            android:layout_height="@dimen/dp_56"
            android:foreground="?android:attr/selectableItemBackground"
            android:layout_marginHorizontal="@dimen/dp_8"
            android:layout_marginVertical="@dimen/dp_8">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"
                android:src="@drawable/ic_icon"
                android:tint="?attr/titleTextColor"/>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="?attr/titleTextColor"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_2"
                android:text="@string/icons"
                android:lines="1"
                android:fontFamily="@font/helvetica_regular"
                android:paddingHorizontal="@dimen/dp_2"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/llWallpaper"
            android:background="@drawable/bg_corner_8"
            android:layout_width="@dimen/dp_84"
            android:layout_height="@dimen/dp_56"
            android:foreground="?android:attr/selectableItemBackground"
            android:layout_marginHorizontal="@dimen/dp_8"
            android:layout_marginVertical="@dimen/dp_8">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"
                android:src="@drawable/ic_wallpaper"
                android:tint="?attr/titleTextColor"/>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="?attr/titleTextColor"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_2"
                android:text="@string/wallpapers"
                android:lines="1"
                android:fontFamily="@font/helvetica_regular"
                android:paddingHorizontal="@dimen/dp_2"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/llWidget"
            android:background="@drawable/bg_corner_8"
            android:layout_width="@dimen/dp_84"
            android:layout_height="@dimen/dp_56"
            android:foreground="?android:attr/selectableItemBackground"
            android:layout_marginHorizontal="@dimen/dp_8"
            android:layout_marginVertical="@dimen/dp_8">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"
                android:src="@drawable/ic_widget"
                android:tint="?attr/titleTextColor"/>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="?attr/titleTextColor"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_2"
                android:text="@string/widgets"
                android:lines="1"
                android:fontFamily="@font/helvetica_regular"
                android:paddingHorizontal="@dimen/dp_2"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:id="@+id/adContainerBottom"
        android:background="@drawable/bg_ad_container"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dp_64"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.appcompat.widget.LinearLayoutCompat>
