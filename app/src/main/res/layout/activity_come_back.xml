<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guidelineHorizontal"
        android:layout_width="@dimen/dp_1"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.25"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guidelineHorizontal2"
        android:layout_width="@dimen/dp_1"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.75"/>
    <ImageView
        android:id="@+id/ivWelcome"
        android:layout_width="@dimen/dp_150"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_welcome"
        app:layout_constraintBottom_toBottomOf="@+id/guideline"
        app:layout_constraintEnd_toStartOf="@+id/guidelineHorizontal2"
        app:layout_constraintStart_toStartOf="@+id/guidelineHorizontal"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/ivLogo"
        android:visibility="gone"
        android:layout_width="@dimen/dp_150"
        android:layout_height="@dimen/dp_150"
        android:src="@drawable/ic_logo"
        android:scaleType="fitCenter"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@+id/guideline"
        android:layout_width="@dimen/dp_1"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.7"/>
    <ProgressBar
        android:id="@+id/progressBar"
        android:background="@drawable/bg_progress_bar_background"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_84"
        android:max="100"
        android:progress="0"
        android:indeterminate="false"
        android:progressDrawable="@drawable/bg_progress_bar_curved"
        android:layout_marginHorizontal="@dimen/dp_44"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="@dimen/dp_500"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="?attr/titleTextColor"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_12"
        android:text="@string/this_action_may_contain_ads"
        android:fontFamily="@font/inter_regular"
        android:layout_marginHorizontal="@dimen/dp_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>