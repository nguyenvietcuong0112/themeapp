<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12121A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure Home Screen Widget"
            android:textColor="#00E5FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvWidgetId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Widget ID: unknown"
            android:textColor="#888899"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Background configuration Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E2E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Style"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Type"
                android:textColor="#888899"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerBgType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="12dp" />

            <!-- Dynamic field sections -->
            <!-- Solid Section -->
            <LinearLayout
                android:id="@+id/layoutSolidColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solid Color (Hex)"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etBgColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="#1E1E2E"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#00E5FF"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>

            <!-- Gradient Section -->
            <LinearLayout
                android:id="@+id/layoutGradientColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gradient Start Color (Hex)"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etGradientStartColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="#00E5FF"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#00E5FF"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gradient End Color (Hex)"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etGradientEndColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#00E5FF"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>

            <!-- Image Section -->
            <LinearLayout
                android:id="@+id/layoutImageBg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnSelectBgImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose Custom Background Image"
                    android:backgroundTint="#2E2E3E"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvImageUri"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#888899"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:text="No image selected"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Styling config Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E2E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Widget Custom Typography"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Color (Hex)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etTextColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="#FFFFFF"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font Style"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerFont"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSaveConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply Widget Customizations"
            android:backgroundTint="#00E5FF"
            android:textColor="#12121A"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
