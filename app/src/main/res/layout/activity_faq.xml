<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:background="?attr/primaryBackgroundColor" android:layout_width="match_parent" android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_56"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/toolbar_detail"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/dp_12"
        app:layout_constraintBottom_toTopOf="@+id/adContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintVertical_bias="0">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="vertical"
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/titleTextColor"
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:text="@string/_1_the_problem_with_the_watermark_in_the_lower_right_corner_of_the_icon"
                android:fontFamily="@font/helvetica_medium"
                android:layout_marginHorizontal="@dimen/dp_16"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/detailTextColor"
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/this_is_due_to_the_system_limitations_of_some_android_models_there_is_cerrently_no_slution_we_can_only_wait_for_the_subsequent_system_to_adapt_to_the_softwawe_and_we_will_tr_our_best_to_optimize_it"
                android:fontFamily="@font/helvetica_regular"
                android:layout_marginHorizontal="@dimen/dp_16"
                android:layout_marginVertical="@dimen/dp_4"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/titleTextColor"
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_12"
                android:text="@string/_2_how_to_turn_on_permissions_install_icon"
                android:fontFamily="@font/helvetica_medium"
                android:layout_marginHorizontal="@dimen/dp_16"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/detailTextColor"
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/click_install_to_pop_up_a_prompt_to_open_the_pop_up_permission_window_and_click_ok_to_jump_to_the_system_permissions_page_to_enable_the_permission_to_create_shortcuts"
                android:fontFamily="@font/helvetica_regular"
                android:layout_marginHorizontal="@dimen/dp_16"
                android:layout_marginVertical="@dimen/dp_4"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/titleTextColor"
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_12"
                android:text="@string/_3_turn_on_positioning_permission_for_precise_positioning_weather_widget"
                android:fontFamily="@font/helvetica_medium"
                android:layout_marginHorizontal="@dimen/dp_16"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/detailTextColor"
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/for_the_first_time_a_pop_up_window_prompts_to_open_the_location_permission_click_ok_to_jump_to_the_system_positioning_page_to_enable_the_allow_all_the_time_positioning_permission_to_obtain_more_precise_positioning_after_successfully_adding_the_desktop_you_need_to_wait_for_about_2_to_3_seconds_to_obtain_the_weather_data"
                android:fontFamily="@font/helvetica_regular"
                android:layout_marginHorizontal="@dimen/dp_16"
                android:layout_marginVertical="@dimen/dp_4"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:id="@+id/adContainer"
        android:background="@drawable/bg_ad_container"
        android:padding="@dimen/dp_2"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dp_64"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>