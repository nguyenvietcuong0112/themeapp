<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:background="?attr/primaryBackgroundColor" android:layout_width="match_parent" android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/toolbar_detail"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/adContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_24">
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:background="@drawable/bg_circle"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:text="1"
                    android:fontFamily="@font/helvetica_regular"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:backgroundTint="@color/colorFFC9D5"/>
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_step_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_a_widget_to_click"
                    android:fontFamily="@font/helvetica_regular"
                    android:paddingHorizontal="@dimen/dp_24"
                    android:paddingVertical="@dimen/dp_8"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:src="@drawable/bg_widget_step_1"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_24">
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:background="@drawable/bg_circle"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:text="2"
                    android:fontFamily="@font/helvetica_regular"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:backgroundTint="@color/color9FD6FF"/>
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_step_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/swipe_left_and_right_to_save_your_favorite_widget"
                    android:fontFamily="@font/helvetica_regular"
                    android:paddingHorizontal="@dimen/dp_24"
                    android:paddingVertical="@dimen/dp_8"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:src="@drawable/bg_widget_step_2"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_24">
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:background="@drawable/bg_circle"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:text="3"
                    android:fontFamily="@font/helvetica_regular"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:backgroundTint="@color/colorDAFF7D"/>
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_step_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/click_add_and_add_to_home_screen"
                    android:fontFamily="@font/helvetica_regular"
                    android:paddingHorizontal="@dimen/dp_24"
                    android:paddingVertical="@dimen/dp_8"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:src="@drawable/bg_widget_step_3"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_24">
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:background="@drawable/bg_circle"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:text="4"
                    android:fontFamily="@font/helvetica_regular"
                    android:layout_marginEnd="@dimen/dp_8"
                    android:backgroundTint="@color/colorFFE888"/>
                <TextView
                    android:textColor="@color/black"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_step_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/go_back_to_the_home_screen_and_enjoy_it"
                    android:fontFamily="@font/helvetica_regular"
                    android:paddingHorizontal="@dimen/dp_24"
                    android:paddingVertical="@dimen/dp_8"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:src="@drawable/bg_widget_step_4"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:layout_weight="1"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:id="@+id/adContainer"
        android:background="@drawable/bg_ad_container"
        android:padding="@dimen/dp_2"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dp_64"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>