<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:orientation="vertical" android:background="?attr/primaryBackgroundColor" android:layout_width="match_parent" android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/toolbar_my_theme"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/llTab"
        android:background="@drawable/bg_corner_8"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_36"
        android:layout_marginTop="@dimen/dp_8"
        android:layout_marginBottom="@dimen/dp_4"
        android:backgroundTint="?attr/tabBackgroundColor"
        android:layout_marginHorizontal="@dimen/dp_16"
        app:layout_constraintBottom_toTopOf="@+id/viewPager"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintWidth_max="@dimen/dp_380">
        <TextView
            android:textColor="@color/black"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tvMine"
            android:background="@drawable/tab_indicator_primary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/dp_2"
            android:text="@string/mine"
            android:maxLines="1"
            android:layout_weight="1"
            android:fontFamily="@font/helvetica_medium"
            android:paddingHorizontal="@dimen/dp_4"/>
        <View
            android:layout_gravity="center_vertical"
            android:background="?attr/tabBackgroundColor"
            android:layout_width="@dimen/dp_1"
            android:layout_height="@dimen/dp_20"/>
        <TextView
            android:textColor="@color/black"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tvFavorite"
            android:background="@drawable/tab_indicator_primary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/dp_2"
            android:text="@string/favorite"
            android:maxLines="1"
            android:layout_weight="1"
            android:fontFamily="@font/helvetica_medium"
            android:paddingHorizontal="@dimen/dp_4"/>
        <View
            android:layout_gravity="center_vertical"
            android:background="?attr/tabBackgroundColor"
            android:layout_width="@dimen/dp_1"
            android:layout_height="@dimen/dp_20"/>
        <TextView
            android:textColor="@color/black"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tvCustomize"
            android:background="@drawable/tab_indicator_primary"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/dp_2"
            android:text="@string/customize"
            android:maxLines="1"
            android:layout_weight="1"
            android:fontFamily="@font/helvetica_medium"
            android:paddingHorizontal="@dimen/dp_4"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_0"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_weight="1"
        app:layout_constraintBottom_toTopOf="@+id/adContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llTab"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:id="@+id/adContainer"
        android:background="@drawable/bg_ad_container"
        android:padding="@dimen/dp_2"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dp_64"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:gravity="center"
        android:id="@+id/tvCreate"
        android:background="@drawable/bg_fab"
        android:padding="@dimen/dp_8"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        android:layout_marginBottom="@dimen/dp_16"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_add_background"
        android:layout_marginEnd="@dimen/dp_16"
        app:layout_constraintBottom_toTopOf="@+id/adContainer"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>