<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#12121A"
    android:padding="16dp">

    <!-- Title Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DIY Keyboard Theme Creator"
        android:textColor="#00E5FF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Keyboard Live Preview Frame -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Keyboard Preview:"
        android:textColor="#888899"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <FrameLayout
        android:id="@+id/keyboardPreviewContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F0F15"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <!-- KeyboardView will be added here dynamically for live preview -->
    </FrameLayout>

    <!-- Scrollable Customizer Settings -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theme Name"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etThemeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cyberpunk DIY"
                android:textColor="#FFFFFF"
                android:textColorHint="#555566"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keyboard Background Color (Hex)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etBgColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="#12121A"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Background Color (Hex)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etKeyBgColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="#1E1E2E"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Text Color (Hex)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etKeyTextColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="#00E5FF"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Outline/Stroke Color (Hex)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etKeyShadowColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="#3300E5FF"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvRadiusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Corner Rounding: 12dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <SeekBar
                android:id="@+id/sbBorderRadius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="12"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font Style"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerFont"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#00E5FF"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnSaveTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save &amp; Apply Theme"
                android:backgroundTint="#00E5FF"
                android:textColor="#12121A"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
