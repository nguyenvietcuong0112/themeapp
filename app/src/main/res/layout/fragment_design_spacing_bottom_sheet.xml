<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ctContainer"
        android:background="@drawable/bg_design_bottom_sheet_corner_16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/tabBackgroundColor"
        app:layout_constraintBottom_toBottomOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbarHeight"
            android:paddingHorizontal="@dimen/dp_16"
            app:layout_constraintBottom_toTopOf="@+id/clLineSpacing">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivClose"
                android:padding="@dimen/dp_2"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="@dimen/dp_28"
                android:layout_height="@dimen/dp_28"
                android:foreground="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/titleTextColor"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/dp_150"
                android:text="@string/spacing"
                android:maxLines="1"
                android:fontFamily="?attr/fontMedium"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivDone"
                android:padding="@dimen/dp_2"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="@dimen/dp_28"
                android:layout_height="@dimen/dp_28"
                android:foreground="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_design_done"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clLineSpacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_16"
            app:layout_constraintBottom_toTopOf="@+id/clLetterSpacing">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="?attr/titleTextColor"
                android:id="@+id/tvLineSpacing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dp_4"
                android:text="@string/line_spacing"
                android:fontFamily="?attr/fontRegular"
                android:layout_marginStart="@dimen/dp_16"
                app:layout_constraintBottom_toTopOf="@+id/sbLineSpacing"
                app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="?attr/titleTextColor"
                android:id="@+id/tvProgressLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dp_4"
                android:fontFamily="?attr/fontRegular"
                android:layout_marginEnd="@dimen/dp_16"
                app:layout_constraintBottom_toTopOf="@+id/sbLineSpacing"
                app:layout_constraintEnd_toEndOf="parent"/>
            <SeekBar
                android:id="@+id/sbLineSpacing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:max="250"
                android:thumb="@drawable/ic_design_circle_thumb"
                android:paddingStart="@dimen/dp_6"
                android:paddingEnd="@dimen/dp_6"
                android:progressTint="?attr/primaryColor"
                android:min="50"
                android:layout_marginHorizontal="@dimen/dp_16"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clLetterSpacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_24"
            app:layout_constraintBottom_toBottomOf="parent">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="?attr/titleTextColor"
                android:id="@+id/tvLetterSpacing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dp_4"
                android:text="@string/letter_spacing"
                android:fontFamily="?attr/fontRegular"
                android:layout_marginStart="@dimen/dp_16"
                app:layout_constraintBottom_toTopOf="@+id/sbLetterSpacing"
                app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="?attr/titleTextColor"
                android:id="@+id/tvProgressLetter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dp_4"
                android:fontFamily="?attr/fontRegular"
                android:layout_marginEnd="@dimen/dp_16"
                app:layout_constraintBottom_toTopOf="@+id/sbLetterSpacing"
                app:layout_constraintEnd_toEndOf="parent"/>
            <SeekBar
                android:id="@+id/sbLetterSpacing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:max="125"
                android:thumb="@drawable/ic_design_circle_thumb"
                android:paddingStart="@dimen/dp_6"
                android:paddingEnd="@dimen/dp_6"
                android:progressTint="?attr/primaryColor"
                android:min="0"
                android:layout_marginHorizontal="@dimen/dp_16"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>