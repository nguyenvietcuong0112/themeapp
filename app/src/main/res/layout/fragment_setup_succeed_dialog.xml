<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="?attr/primaryBackgroundColor" app:cardCornerRadius="@dimen/dp_16" app:cardElevation="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivClose"
            android:background="@drawable/bg_circle"
            android:padding="@dimen/dp_6"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/dp_32"
            android:layout_height="@dimen/dp_32"
            android:layout_marginTop="@dimen/dp_20"
            android:foreground="?android:attr/selectableItemBackground"
            android:src="@drawable/ic_close"
            android:tint="@color/white"
            android:layout_marginEnd="@dimen/dp_16"
            android:elevation="@dimen/dp_24"
            android:backgroundTint="@color/gray333333Alpha50"
            android:clipToOutline="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="vertical"
            android:background="?attr/primaryBackgroundColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/dp_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/llHeader">
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textSize="@dimen/sp_22"
                        android:textColor="?attr/titleTextColor"
                        android:gravity="center"
                        android:layout_gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_4"
                        android:text="@string/successful"
                        android:layout_weight="1"
                        android:fontFamily="@font/helvetica_medium"
                        android:layout_marginHorizontal="@dimen/dp_56"/>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_gravity="center_horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_4"
                        android:layout_marginHorizontal="@dimen/dp_12">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/dp_32"
                            android:layout_height="@dimen/dp_32"
                            android:src="@drawable/ic_succeed"/>
                        <TextView
                            android:textSize="@dimen/sp_16"
                            android:textColor="@color/color3DD225"
                            android:gravity="center"
                            android:layout_gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/install_successfully"
                            android:fontFamily="@font/helvetica_medium"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_gravity="center_horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="@dimen/dp_16">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_200"
                            android:src="@drawable/bg_successful"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <androidx.cardview.widget.CardView
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="@dimen/dp_12"
                            app:cardElevation="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_gravity="center"
                                android:id="@+id/ivWallpaper"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_100"
                                android:layout_height="@dimen/dp_200"
                                android:scaleType="centerInside"
                                android:adjustViewBounds="true"/>
                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_gravity="center"
                                android:id="@+id/ivWidget"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_200"
                                android:layout_height="@dimen/dp_100"
                                android:scaleType="centerInside"
                                android:adjustViewBounds="true"/>
                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:id="@+id/llIcon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">
                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_gravity="center"
                                    android:id="@+id/ivIcon"
                                    android:layout_width="@dimen/dp_72"
                                    android:layout_height="@dimen/dp_72"
                                    android:scaleType="fitCenter"
                                    android:adjustViewBounds="true"/>
                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    android:orientation="vertical"
                                    android:id="@+id/llTotal"
                                    android:background="@drawable/bg_corner_16"
                                    android:padding="@dimen/dp_2"
                                    android:layout_width="@dimen/dp_72"
                                    android:layout_height="@dimen/dp_72"
                                    android:scaleType="centerInside"
                                    android:adjustViewBounds="true"
                                    android:layout_marginStart="@dimen/dp_24"
                                    android:backgroundTint="@color/grayF2F2F2">
                                    <TextView
                                        android:textSize="@dimen/sp_14"
                                        android:textColor="?attr/detailTextColor"
                                        android:gravity="center"
                                        android:id="@+id/tvTotal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:lines="1"
                                        android:fontFamily="@font/helvetica_medium"/>
                                    <TextView
                                        android:textSize="@dimen/sp_12"
                                        android:textColor="?attr/detailTextColor"
                                        android:gravity="center"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="@string/more_icon"
                                        android:lines="1"
                                        android:fontFamily="@font/helvetica_medium"/>
                                </androidx.appcompat.widget.LinearLayoutCompat>
                            </androidx.appcompat.widget.LinearLayoutCompat>
                        </androidx.cardview.widget.CardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <TextView
                        android:textSize="@dimen/sp_16"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_gravity="center_vertical"
                        android:id="@+id/tvOk"
                        android:background="@drawable/bg_button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_44"
                        android:text="@string/ok"
                        android:fontFamily="@font/helvetica_medium"
                        android:backgroundTint="@color/secondaryPrimary"
                        android:layout_marginHorizontal="@dimen/dp_32"/>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:gravity="center"
                        android:id="@+id/adContainer"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_260"
                        android:layout_marginTop="@dimen/dp_12"
                        android:layout_marginHorizontal="@dimen/dp_8"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.core.widget.NestedScrollView>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>