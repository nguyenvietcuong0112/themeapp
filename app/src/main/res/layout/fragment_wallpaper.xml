<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="match_parent">
    <ProgressBar
        android:layout_gravity="center"
        android:id="@+id/pbCreate"
        android:tag="binding_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="vertical"
            android:tag="binding_2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar">
            <include
                android:id="@+id/toolbar"
                layout="@layout/toolbar_theme"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/categoryRecyclerView"
                android:tag="binding_3"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_32"
                android:layout_marginBottom="@dimen/dp_4"
                android:layout_marginHorizontal="@dimen/dp_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/toolbar"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:tag="binding_4"
                android:paddingBottom="@dimen/dp_120"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="@dimen/dp_8"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/categoryRecyclerView"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_gravity="end|bottom"
        android:orientation="vertical"
        android:id="@+id/viewBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_16">
        <androidx.appcompat.widget.AppCompatImageView
            android:gravity="center"
            android:layout_gravity="end|bottom"
            android:id="@+id/tvCreate"
            android:background="@drawable/bg_fab"
            android:padding="@dimen/dp_8"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_48"
            android:layout_marginBottom="@dimen/dp_16"
            android:foreground="?android:attr/selectableItemBackground"
            android:src="@drawable/ic_add_background"
            android:layout_above="@+id/tvAdd"
            android:layout_alignParentEnd="true"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:gravity="center"
            android:id="@+id/tvAdd"
            android:background="@drawable/bg_fab"
            android:padding="@dimen/dp_8"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/dp_48"
            android:layout_height="@dimen/dp_48"
            android:layout_marginBottom="@dimen/dp_12"
            android:foreground="?android:attr/selectableItemBackground"
            android:src="@drawable/ic_theme_home"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</FrameLayout>