<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:background="@color/transparent" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:id="@+id/cvImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/transparent"
        app:cardCornerRadius="@dimen/dp_8"
        app:cardElevation="@dimen/dp_0">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"/>
        <View
            android:id="@+id/clickView"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:foreground="?android:attr/selectableItemBackground"
            android:translationZ="@dimen/dp_20"/>
    </androidx.cardview.widget.CardView>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivSelect"
        android:background="@drawable/bg_circle"
        android:padding="@dimen/dp_4"
        android:visibility="gone"
        android:layout_width="@dimen/dp_18"
        android:layout_height="@dimen/dp_18"
        android:layout_marginTop="@dimen/dp_4"
        android:src="@drawable/ic_tick"
        android:adjustViewBounds="true"
        android:layout_marginEnd="@dimen/dp_4"
        android:translationZ="@dimen/dp_8"
        android:backgroundTint="@color/primary"
        app:layout_constraintEnd_toEndOf="@+id/cvImage"
        app:layout_constraintTop_toTopOf="@+id/cvImage"/>
</androidx.constraintlayout.widget.ConstraintLayout>