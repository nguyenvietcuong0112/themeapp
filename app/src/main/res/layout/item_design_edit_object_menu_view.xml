<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"  android:layout_width="wrap_content" android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivDuplicate"
        android:background="@drawable/bg_corner_6"
        android:padding="@dimen/dp_8"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/dp_36"
        android:layout_height="@dimen/dp_36"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_marginBottom="@dimen/dp_12"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_design_duplicate_menu_view"
        android:tint="?attr/titleTextColor"
        android:layout_marginStart="@dimen/dp_12"
        android:layout_marginEnd="@dimen/dp_6"
        android:elevation="@dimen/dp_8"
        android:backgroundTint="?attr/secondaryBackgroundColor"
        android:outlineSpotShadowColor="@color/black"
        android:outlineAmbientShadowColor="@color/black"
        android:clipToOutline="true"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivCopy"
        android:background="@drawable/bg_corner_6"
        android:padding="@dimen/dp_8"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/dp_36"
        android:layout_height="@dimen/dp_36"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_marginBottom="@dimen/dp_12"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_design_copy_menu_view"
        android:tint="?attr/titleTextColor"
        android:layout_marginStart="@dimen/dp_6"
        android:layout_marginEnd="@dimen/dp_6"
        android:elevation="@dimen/dp_8"
        android:backgroundTint="?attr/secondaryBackgroundColor"
        android:outlineSpotShadowColor="@color/black"
        android:outlineAmbientShadowColor="@color/black"
        android:clipToOutline="true"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivReplaceImage"
        android:background="@drawable/bg_corner_6"
        android:padding="@dimen/dp_8"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/dp_36"
        android:layout_height="@dimen/dp_36"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_marginBottom="@dimen/dp_12"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_replace_image_menu_view"
        android:tint="?attr/titleTextColor"
        android:layout_marginStart="@dimen/dp_6"
        android:layout_marginEnd="@dimen/dp_6"
        android:elevation="@dimen/dp_8"
        android:backgroundTint="?attr/secondaryBackgroundColor"
        android:outlineSpotShadowColor="@color/black"
        android:outlineAmbientShadowColor="@color/black"
        android:clipToOutline="true"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivDelete"
        android:background="@drawable/bg_corner_6"
        android:padding="@dimen/dp_8"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/dp_36"
        android:layout_height="@dimen/dp_36"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_marginBottom="@dimen/dp_12"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_design_delete_menu_view"
        android:tint="?attr/titleTextColor"
        android:layout_marginStart="@dimen/dp_6"
        android:layout_marginEnd="@dimen/dp_12"
        android:elevation="@dimen/dp_8"
        android:backgroundTint="?attr/secondaryBackgroundColor"
        android:outlineSpotShadowColor="@color/black"
        android:outlineAmbientShadowColor="@color/black"
        android:clipToOutline="true"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivAddImageToFrame"
        android:background="@drawable/bg_corner_6"
        android:padding="@dimen/dp_8"
        android:focusable="true"
        android:visibility="visible"
        android:clickable="true"
        android:layout_width="@dimen/dp_36"
        android:layout_height="@dimen/dp_36"
        android:layout_marginTop="@dimen/dp_4"
        android:layout_marginBottom="@dimen/dp_12"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_design_add_image_into_frame"
        android:tint="?attr/titleTextColor"
        android:layout_marginStart="@dimen/dp_6"
        android:layout_marginEnd="@dimen/dp_6"
        android:elevation="@dimen/dp_8"
        android:backgroundTint="?attr/secondaryBackgroundColor"
        android:outlineSpotShadowColor="@color/black"
        android:outlineAmbientShadowColor="@color/black"
        android:clipToOutline="true"/>
</androidx.appcompat.widget.LinearLayoutCompat>