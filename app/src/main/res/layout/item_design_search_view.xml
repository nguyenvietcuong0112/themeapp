<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"  android:orientation="horizontal" android:id="@+id/searchBar" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="@dimen/dp_4">
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/ivSearch"
        android:padding="@dimen/dp_4"
        android:visibility="gone"
        android:layout_width="@dimen/dp_28"
        android:layout_height="@dimen/dp_28"
        android:src="@drawable/ic_search"/>
    <androidx.appcompat.widget.AppCompatEditText
        android:textSize="@dimen/sp_14"
        android:textColor="?attr/titleTextColor"
        android:textColorHint="?attr/thirdTextColor"
        android:gravity="center_vertical"
        android:id="@+id/tvSearch"
        android:background="@android:color/transparent"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:hint="@string/search"
        android:singleLine="true"
        android:layout_weight="1"
        android:imeOptions="actionSearch"
        android:fontFamily="?attr/fontRegular"
        android:paddingHorizontal="@dimen/dp_8"/>
    <FrameLayout
        android:layout_gravity="center_vertical"
        android:id="@+id/flClose"
        android:visibility="gone"
        android:layout_width="@dimen/dp_32"
        android:layout_height="@dimen/dp_32">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_gravity="center"
            android:id="@+id/ivClose"
            android:background="@drawable/bg_circle"
            android:padding="@dimen/dp_6"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            android:src="@drawable/ic_close"
            android:tint="@color/white"
            android:backgroundTint="@color/thirdTextColor"/>
    </FrameLayout>
</androidx.appcompat.widget.LinearLayoutCompat>