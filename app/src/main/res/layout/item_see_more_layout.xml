<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:id="@+id/cardView2" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginHorizontal="@dimen/dp_8" android:layout_marginVertical="@dimen/dp_8" app:cardCornerRadius="@dimen/dp_12">
