<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:id="@+id/clipboard_manager_holder"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <RelativeLayout
            android:gravity="center_vertical"
            android:id="@+id/clipboard_manager_top_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivBack"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/small_margin"
                android:layout_width="@dimen/toolbar_icon_height"
                android:layout_height="@dimen/toolbar_icon_height"
                android:src="@drawable/ic_back"
                android:tint="?attr/titleTextColor"
                android:layout_centerVertical="true"
                android:contentDescription="@string/clipboard"
                android:layout_marginStart="@dimen/medium_margin"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="?attr/titleTextColor"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/clipboard_manager_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/keyboard_settings"
                android:lines="1"
                android:layout_centerVertical="true"
                android:fontFamily="@font/inter_medium"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true"
                android:layout_marginHorizontal="@dimen/dp_44"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivSetting"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="@dimen/dp_28"
                android:layout_height="@dimen/dp_28"
                android:foreground="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_settings_cog_vector"
                android:tint="?attr/primaryColor"
                android:layout_centerVertical="true"
                android:contentDescription="@string/clipboard_pinned"
                android:layout_marginEnd="@dimen/dp_12"
                android:layout_alignParentEnd="true"
                android:clipToOutline="true"/>
        </RelativeLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/settingRecyclerView"
            android:tag="binding_1"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentTop="true"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_marginHorizontal="@dimen/dp_16"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.constraintlayout.widget.ConstraintLayout>