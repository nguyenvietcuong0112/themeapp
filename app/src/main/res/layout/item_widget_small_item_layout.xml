<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:id="@+id/ctContainer" android:background="@drawable/bg_corner_16" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="@dimen/dp_8" android:foreground="?android:attr/selectableItemBackground" android:backgroundTint="@color/transparent" android:clipToOutline="true">
    <androidx.appcompat.widget.AppCompatImageView
