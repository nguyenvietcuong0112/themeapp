<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:background="?attr/secondaryBackgroundColor" android:layout_width="match_parent" android:layout_height="@dimen/toolbarHeight">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivLeft"
        android:padding="@dimen/dp_2"
        android:layout_width="@dimen/dp_28"
        android:layout_height="@dimen/dp_28"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_back"
        android:tint="?attr/titleTextColor"
        android:layout_marginStart="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="?attr/titleTextColor"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:maxWidth="@dimen/dp_160"
        android:text="@string/reposition"
        android:maxLines="1"
        android:fontFamily="?attr/fontMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivRight"
        android:padding="@dimen/dp_2"
        android:layout_width="@dimen/dp_28"
        android:layout_height="@dimen/dp_28"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_design_done"
        android:tint="?attr/titleTextColor"
        android:layout_marginEnd="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>