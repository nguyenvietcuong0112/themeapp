<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="@dimen/toolbarHeight">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivClose"
        android:tag="binding_1"
        android:padding="@dimen/dp_3"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="@dimen/dp_28"
        android:layout_height="@dimen/dp_28"
        android:foreground="?android:attr/selectableItemBackground"
        android:layout_marginStart="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/titleTextColor"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="?attr/titleTextColor"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sticker"
        android:fontFamily="?attr/fontMedium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivSearch"
        android:tag="binding_2"
        android:padding="@dimen/dp_3"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="@dimen/dp_28"
        android:layout_height="@dimen/dp_28"
        android:foreground="?android:attr/selectableItemBackground"
        android:layout_marginEnd="@dimen/dp_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/titleTextColor"/>
</androidx.constraintlayout.widget.ConstraintLayout>