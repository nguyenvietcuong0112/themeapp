<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/viewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="@dimen/dp_16"
            app:cardElevation="@dimen/dp_0">
            <ImageView
                android:id="@+id/ivBackground"
                android:background="@drawable/bg_corner_16"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:clipToOutline="true"/>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:layout_marginVertical="@dimen/dp_16">
            <TextView
                android:textSize="@dimen/sp_48"
                android:textStyle="bold"
                android:textColor="#00233e"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/tvClock"
                android:background="@drawable/bg_clock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="12:56"
                android:lines="1"
                android:fontFamily="@font/helvetica_bold"
                android:format12Hour="HH mm"
                android:format24Hour="HH mm"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="@dimen/sp_32"/>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>