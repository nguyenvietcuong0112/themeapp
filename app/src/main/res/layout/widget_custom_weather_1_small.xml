<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/viewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="@dimen/dp_16"
            app:cardElevation="@dimen/dp_0">
            <ImageView
                android:id="@+id/ivBackground"
                android:background="@drawable/bg_corner_16"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:clipToOutline="true"/>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_gravity="start|top"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_2"
            android:layout_marginHorizontal="@dimen/dp_8">
            <TextView
                android:textSize="@dimen/sp_22"
                android:textStyle="bold"
                android:textColor="#00233e"
                android:id="@+id/tvTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="29°C"
                android:fontFamily="@font/helvetica_bold"
                android:autoSizeMinTextSize="@dimen/sp_16"
                android:autoSizeMaxTextSize="@dimen/sp_22"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="#00233e"
                android:id="@+id/tvFeelsLike"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-4dp"
                android:text="Feels like 29°C"
                android:fontFamily="@font/helvetica_medium"
                android:autoSizeMinTextSize="@dimen/sp_8"
                android:autoSizeMaxTextSize="@dimen/sp_10"/>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_8"
            android:layout_marginHorizontal="@dimen/dp_8">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textStyle="bold"
                    android:textColor="#00233e"
                    android:id="@+id/tvWeekday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="-4dp"
                    android:text="Sunday"
                    android:fontFamily="@font/helvetica_bold"
                    android:autoSizeMinTextSize="@dimen/sp_10"
                    android:autoSizeMaxTextSize="@dimen/sp_12"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="#00233e"
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="December 25"
                    android:lines="1"
                    android:fontFamily="@font/helvetica_medium"
                    android:autoSizeMinTextSize="@dimen/sp_8"
                    android:autoSizeMaxTextSize="@dimen/sp_10"/>
            </LinearLayout>
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <LinearLayout
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="#00233e"
                    android:id="@+id/tvHTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="-4dp"
                    android:text="H: 29°C"
                    android:lines="1"
                    android:fontFamily="@font/helvetica_medium"
                    android:autoSizeMinTextSize="@dimen/sp_8"
                    android:autoSizeMaxTextSize="@dimen/sp_10"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="#00233e"
                    android:id="@+id/tvLTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="L: 19°C"
                    android:lines="1"
                    android:fontFamily="@font/helvetica_medium"
                    android:autoSizeMinTextSize="@dimen/sp_8"
                    android:autoSizeMaxTextSize="@dimen/sp_10"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>