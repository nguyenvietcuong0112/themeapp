<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"  android:layout_width="match_parent" android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/viewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="@dimen/dp_16"
            app:cardElevation="@dimen/dp_0">
            <ImageView
                android:id="@+id/ivBackground"
                android:background="@drawable/bg_corner_16"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:clipToOutline="true"/>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="@dimen/dp_12"
            android:layout_marginVertical="@dimen/dp_12">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/ivLocation"
                    android:layout_width="@dimen/dp_28"
                    android:layout_height="@dimen/dp_28"
                    android:src="@drawable/ic_location"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="#00233e"
                    android:layout_gravity="center"
                    android:id="@+id/tvLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="London"
                    android:layout_weight="1"
                    android:fontFamily="@font/helvetica_medium"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="@dimen/sp_12"/>
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textStyle="bold"
                    android:textColor="#00233e"
                    android:ellipsize="end"
                    android:gravity="end|center_vertical"
                    android:layout_gravity="end|center_vertical"
                    android:id="@+id/tvDay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Monday"
                    android:lines="1"
                    android:layout_weight="1"
                    android:fontFamily="@font/helvetica_bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="@dimen/sp_16"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/ivWeather"
                    android:layout_width="@dimen/dp_72"
                    android:layout_height="@dimen/dp_72"
                    android:src="@drawable/ic_02d"
                    android:layout_marginEnd="@dimen/dp_16"/>
                <TextView
                    android:textSize="@dimen/sp_64"
                    android:textStyle="bold"
                    android:textColor="#00233e"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/tvTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21°"
                    android:lines="1"
                    android:fontFamily="@font/helvetica_bold"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="@dimen/sp_32"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="#00233e"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/tvHTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="H: 29C"
                    android:fontFamily="@font/helvetica_medium"
                    android:layout_marginEnd="@dimen/dp_16"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="@dimen/sp_14"/>
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="#00233e"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tvLTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="L: 19C"
                    android:fontFamily="@font/helvetica_medium"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="@dimen/sp_14"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>