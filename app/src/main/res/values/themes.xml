<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Custom personalization theme attributes -->
        <item name="primaryBackgroundColor">#12121A</item>
        <item name="secondaryBackgroundColor">#1E1E2E</item>
        <item name="titleTextColor">#FFFFFF</item>
        <item name="detailTextColor">#888899</item>
        <item name="lineColor">#33FFFFFF</item>
        <item name="primaryColor">#00E5FF</item>
        <item name="tabBackgroundColor">#2E2E3E</item>
    </style>
</resources>